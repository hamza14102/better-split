{
    "expo": {
        "name": "Better Split",
        "slug": "better-split",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "light",
        "newArchEnabled": true,
        "splash": {
            "image": "./assets/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#FAF8F1"
        },
        "ios": {
            "supportsTablet": true
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#FAF8F1"
            },
            "edgeToEdgeEnabled": true
        },
        "web": {
            "favicon": "./assets/favicon.png"
        },
        "primaryColor": "#8B8B6E",
        "description": "A Splitwise-style app for sharing expenses with friends",
        "androidStatusBar": {
            "backgroundColor": "#FAF8F1",
            "barStyle": "dark-content"
        }
    }
}
